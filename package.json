{
  "name": "quelleroulotte",
  "version": "2.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.cjs",
  "scripts": {
    "start": "npm run build && npm run electron:start",
    "build": "npm run typecheck && node util/esbuild.js",
    "typecheck": "tsc",
    "electron:start": "electron .",
    "dist": "npm run build && electron-builder --dir",
    "lint": "eslint .",
    "prettier": "prettier --write frontend/ src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AxelTerizaki/quelleroulotte.git"
  },
  "author": "Guillaume Lebigot",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AxelTerizaki/quelleroulotte/issues"
  },
  "homepage": "https://github.com/AxelTerizaki/quelleroulotte#readme",
  "dependencies": {
    "google-auth-library": "^10.9.0",
    "google-spreadsheet": "^5.3.0",
    "markdown-pro": "^1.1.8",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/source-map-support": "^0.5.10",
    "@typescript-eslint/eslint-plugin": "~7.18.0",
    "@typescript-eslint/parser": "~7.18.0",
    "electron": "~24.8.8",
    "electron-builder": "~24.13.3",
    "esbuild": "^0.28.1",
    "eslint": "~8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "build": {
    "appId": "QuelleRoulotte",
    "npmRebuild": "false",
    "win": {
      "target": [
        "zip"
      ],
      "compression": "normal",
      "publisherName": "Ouestampes",
      "verifyUpdateCodeSignature": false
    },
    "productName": "Quelle Roulotte?",
    "copyright": "© 2023 Ouestampes",
    "extraResources": [
      "frontend/**",
      "creds.json"
    ],
    "directories": {
      "output": "packages"
    },
    "files": [
      "dist/*",
      "package.json",
      "!**/node_modules/**/*"
    ]
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
